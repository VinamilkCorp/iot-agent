{
  "name": "iot-scale",
  "version": "1.0.0",
  "description": "IoT Scale Desktop App",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux",
    "publish": "electron-builder --publish always",
    "publish:win": "electron-builder --win --publish always",
    "publish:mac": "electron-builder --mac --publish always",
    "publish:all": "electron-builder --win --mac --publish always"
  },
  "build": {
    "appId": "com.yourcompany.iot-scale",
    "productName": "IoT Scale",
    "publish": {
      "provider": "github",
      "owner": "VinamilkCorp",
      "repo": "iot-agent"
    },
    "win": {
      "target": "nsis",
      "protocols": [{ "name": "IoT Scale Auth", "schemes": ["iotscale"] }]
    },
    "mac": {
      "target": "dmg",
      "protocols": [{ "name": "IoT Scale Auth", "schemes": ["iotscale"] }]
    },
    "linux": {
      "target": "AppImage"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "src/**/*",
      "node_modules/keycloak-js/**/*"
    ]
  },
  "dependencies": {
    "@serialport/parser-readline": "^12.0.0",
    "electron-updater": "^6.1.7",
    "keycloak-js": "^26.2.3",
    "dotenv": "^16.0.0",
    "serialport": "^12.0.0"
  },
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^24.9.1"
  }
}
