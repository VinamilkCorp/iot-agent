{
  "name": "iot-scale",
  "version": "1.1.13",
  "description": "IoT Scale Desktop App",
  "main": "main.js",
  "author": {
    "name": "Vinamilk",
    "email": "tavan@vinamilk.com.vn"
  },
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux",
    "publish": "electron-builder --publish always",
    "publish:winx64": "electron-builder --win --x64 --publish always",
    "publish:winN": "electron-builder --win --publish always",
    "publish:win": "concurrently \"npm run publish:winN\" \"npm run publish:winx64\"",
    "publish:mac": "electron-builder --mac --publish always",
    "publish:all": "electron-builder --win --mac --publish always"
  },
  "build": {
    "appId": "com.yourcompany.iot-scale",
    "productName": "IoT Scale",
    "publish": {
      "provider": "github",
      "owner": "VinamilkCorp",
      "repo": "iot-agent"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "runAfterFinish": true,
      "deleteAppDataOnUninstall": true,
      "perMachine": false,
      "language": "1066",
      "include": "build/installer.nsh",
      "installerLanguages": [
        "vi_VN"
      ]
    },
    "win": {
      "target": "nsis",
      "protocols": [
        {
          "name": "IoT Scale Auth",
          "schemes": [
            "iotscale"
          ]
        }
      ]
    },
    "mac": {
      "target": "dmg",
      "protocols": [
        {
          "name": "IoT Scale Auth",
          "schemes": [
            "iotscale"
          ]
        }
      ]
    },
    "linux": {
      "target": "AppImage"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "src/**/*",
      "node_modules/keycloak-js/**/*"
    ],
    "extraResources": [
      {
        "from": ".env",
        "to": ".env"
      },
      {
        "from": "drivers/CH341SER",
        "to": "drivers/CH341SER"
      }
    ]
  },
  "dependencies": {
    "@serialport/parser-readline": "^13.0.0",
    "ws": "^8.18.0",
    "electron-updater": "^6.1.7",
    "keycloak-js": "^26.2.3",
    "dotenv": "^16.0.0",
    "serialport": "^13.0.0"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "electron": "^29.0.0",
    "electron-builder": "^24.9.1"
  }
}
